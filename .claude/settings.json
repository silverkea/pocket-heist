{
  "permissions": {
    "deny": [
      "Bash(python scripts/set-vercel-env.py*)",
      "Bash(python3 scripts/set-vercel-env.py*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "{ f=$(jq -r '.tool_input.file_path // empty'); case \"$f\" in *.tsx) npx prettier --write \"$f\" ;; esac; } 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true
  }
}
