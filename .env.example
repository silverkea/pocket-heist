# Copy this file to .env.local and fill in the values.
# Never commit .env.local or any file containing real secrets.
#
# Add new environment variables here when introduced,
# with a comment describing what each one is for.

# Firebase client config (public — safe to expose in the browser)
NEXT_PUBLIC_FIREBASE_API_KEY=           # Firebase project API key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=       # e.g. your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=        # Firebase project ID
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=    # e.g. your-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin SDK (server-only — NEVER expose to the client)
FIREBASE_PROJECT_ID=                    # Same as NEXT_PUBLIC_FIREBASE_PROJECT_ID
FIREBASE_CLIENT_EMAIL=                  # Service account client email
FIREBASE_PRIVATE_KEY=                   # Service account private key — JSON-escaped newlines: "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
